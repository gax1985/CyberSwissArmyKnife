        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "git": {
      "command": "C:\\Users\\gax19\\AppData\\Local\\UniGetUI\\Chocolatey\\bin\\uvx.exe",
      "args": [
        "mcp-server-git",
        "--repository",
        "."
      ]
    },
    "time": {
      "command": "C:\\Users\\gax19\\AppData\\Local\\UniGetUI\\Chocolatey\\bin\\uvx.exe",
      "args": [
        "mcp-server-time"
      ]
    },
    "memory": {
      "command": "npx",
      "args": [
