      }
    },
    "nixos": {
      "command": "C:\\Users\\gax19\\AppData\\Local\\UniGetUI\\Chocolatey\\bin\\uvx.exe",
      "args": [
        "mcp-nixos"
      ]
    },
    "kubernetes": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-kubernetes"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "huggingface": {
      "type": "sse",
